# Dist and build directories
dist/
build/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log

# Coverage
coverage/

# Node modules
node_modules/

# OS metadata
.DS_Store
Thumbs.db

# Lock files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore everything in the node_modules folder
node_modules/**

# But allow specific files in node_modules
!node_modules/.bin/*

# Ignore all files in the dist folder
/dist/**

# But allow specific files in dist
!/dist/index.html
!/dist/bank-link-fallback.html

# Ignore all files in the logs folder
/logs/**

# But allow specific files in logs
!/logs/activation.log

# Ignore all files in the coverage folder
/coverage/**

# But allow specific files in coverage
!/coverage/lcov-report/index.html

# Ignore all files in the .env folder
/.env/**

# But allow specific files in .env
!/env.example